<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Rafy Status Screen</title>

  <!-- Pixel font -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Press+Start+2P&display=swap" rel="stylesheet">

  <link rel="stylesheet" href="styles.css" />
</head>

<body>
  <main class="screen" aria-label="RPG status screen">
    <section class="panel">

      <!-- Top tab -->
      <div class="tab" aria-hidden="true">STATUS</div>

      <!-- Header row -->
      <header class="header">
        <div class="nameplate">
          <div class="char-name">RAFY</div>
          <div class="char-class">CLASS: PATHFINDER</div>
          <figure class="portrait">
    <img src="rafy-portrait.png" alt="Rafy portrait">
  </figure>
        </div>

        <div class="levelbox" aria-label="level and vitals">
          <div class="vital-row">
            <span class="label">LV</span>
            <span class="value">16</span>
          </div>
          <div class="vital-row">
            <span class="label">HP</span>
            <span class="value">452/452</span>
          </div>
          <div class="vital-row">
            <span class="label">MP</span>
            <span class="value">118/118</span>
          </div>
          <div class="vital-row">
              <span class="label">TO LV UP</span>
              <span class="value">112</span>
            </div>
            <div class="hint" aria-label="how to use">
            <p>
              Edit numbers in the HTML as you gain points.
              Keep it simple. Consistency beats perfect tracking.
            </p>
          </div>
        </div>

        <div class="classbox" aria-label="class perks">
  <div class="class-title">CLASS PERKS</div>

  <div class="perk">
    <span class="perk-name">Trail Sense</span>
    <span class="perk-effect">+1 RSC on problem-solving quests</span>
  </div>

  <div class="perk">
    <span class="perk-name">Quiet Resolve</span>
    <span class="perk-effect">+1 RES when you do the hard thing first</span>
  </div>

  <div class="perk">
    <span class="perk-name">Mapmaker</span>
    <span class="perk-effect">+1 WSD when you summarize what you learned</span>
  </div>
</div>
      </header>

      <!-- Content grid -->
      <section class="content">

  <section class="stats" aria-label="character stats">
            <h2 class="sr-only">Stats</h2>

            <!-- STRENGTH -->
            <div class="stat" style="--p:36%">
              <div class="stat-top">
                <div class="stat-name">
                  <span class="abbr">STR</span>
                  <span class="full">STRENGTH</span>
                </div>
                <div class="stat-value">18</div>
              </div>
              <div class="bar" role="img" aria-label="Wisdom progress">
                <!-- Set style width to visualize progress (0% to 100%) -->
                <span class="fill"></span>
              </div>
              <p class="stat-desc">
                Physical power and muscular capability developed through training, physical therapy, and demanding physical effort.
              </p>
            </div>

            <!-- STAMINA -->
            <div class="stat" style="--p:40%">
              <div class="stat-top">
                <div class="stat-name">
                  <span class="abbr">STA</span>
                  <span class="full">STAMINA</span>
                </div>
                <div class="stat-value">20</div>
              </div>
              <div class="bar" role="img" aria-label="Wisdom progress">
                <!-- Set style width to visualize progress (0% to 100%) -->
                <span class="fill"></span>
              </div>
              <p class="stat-desc">
                Endurance and sustained energy built through movement, conditioning, nutrition, and proper rest.</p>
            </div>

            <!-- WISDOM -->
            <div class="stat" style="--p:48%">
              <div class="stat-top">
                <div class="stat-name">
                  <span class="abbr">WSD</span>
                  <span class="full">WISDOM</span>
                </div>
                <div class="stat-value">24</div>
              </div>
              <div class="bar" role="img" aria-label="Wisdom progress">
                <!-- Set style width to visualize progress (0% to 100%) -->
                <span class="fill"></span>
              </div>
              <p class="stat-desc">
                Knowledge and insight gained from learning, reading, and life experience.
              </p>
            </div>

            <!-- DEXTERITY -->
            <div class="stat" style="--p:24%">
              <div class="stat-top">
                <div class="stat-name">
                  <span class="abbr">DEX</span>
                  <span class="full">DEXTERITY</span>
                </div>
                <div class="stat-value">12</div>
              </div>
              <div class="bar" role="img" aria-label="Dexterity progress">
                <span class="fill"></span>
              </div>
              <p class="stat-desc">
                Proficiency in digital tools and technical skills (coding, platforms, systems).
              </p>
            </div>

            <!-- CHARISMA -->
            <div class="stat" style="--p:32%">
              <div class="stat-top">
                <div class="stat-name">
                  <span class="abbr">CHA</span>
                  <span class="full">CHARISMA</span>
                </div>
                <div class="stat-value">16</div>
              </div>
              <div class="bar" role="img" aria-label="Charisma progress">
                <span class="fill"></span>
              </div>
              <p class="stat-desc">
                Ability to teach, inspire, and connect with others.
              </p>
            </div>

            <!-- RESILIENCE -->
            <div class="stat" style="--p:28%">
              <div class="stat-top">
                <div class="stat-name">
                  <span class="abbr">RES</span>
                  <span class="full">RESILIENCE</span>
                </div>
                <div class="stat-value">14</div>
              </div>
              <div class="bar" role="img" aria-label="Resilience progress">
                <span class="fill"></span>
              </div>
              <p class="stat-desc">
                Mental fortitude to overcome setbacks and self-doubt.
              </p>
            </div>

            <!-- RESOURCEFULNESS -->
            <div class="stat" style="--p:36%">
              <div class="stat-top">
                <div class="stat-name">
                  <span class="abbr">RSC</span>
                  <span class="full">RESOURCEFULNESS</span>
                </div>
                <div class="stat-value">18</div>
              </div>
              <div class="bar" role="img" aria-label="Resourcefulness progress">
                <span class="fill"></span>
              </div>
              <p class="stat-desc">
                Ability to find creative solutions and manage limited resources.
              </p>
            </div>
          
          </section>

          <section class="quest-log">

<h2>QUEST LOG</h2>

<ul>

<li>
Complete 3 controlled sets of pushups
<span class="reward">+2 STR</span>
</li>  

<li>
Eat clean whole-food meals for the entire day
<span class="reward">+2 STA</span>
</li>

<li>
Read 20 pages of Sovereignty  
<span class="reward">+2 WSD</span>
</li>

<li>
Complete freeCodeCamp lesson  
<span class="reward">+2 DEX</span>
</li>

<li>
Record 5 minute teaching video  
<span class="reward">+2 CHA</span>
</li>

<li>
Solve a difficult life problem creatively  
<span class="reward">+2 RSC</span>
</li>

<li>
Do something hard despite resistance  
<span class="reward">+2 RES</span>
</li>

</ul>

</section>


  </div>

      

      <footer class="footer">
        <div class="footer-left">LOCATION: PUERTO RICO</div>
        <div class="footer-right">SAVE POINT: ACTIVE</div>
      </footer>

    </section>
  </main>
</body>
</html>

